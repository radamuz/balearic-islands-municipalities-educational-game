# Copy to .env and fill in with the values printed by scripts/setup-aws.sh.
# .env is gitignored — never commit real credentials.
#
# With none of these set the app still runs: the mapping is read from the
# committed mapping.json, and the leaderboard/access log stay empty.

AWS_REGION=eu-west-1
DYNAMODB_TABLE=balears-app
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Signs the admin session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Optional: comma-separated origins allowed to call the API with credentials.
# Leave unset for same-origin (production) and local dev.
# CORS_ORIGINS=http://localhost:3000

# Optional: show the access-log tool in the settings wheel.
# FEATURE_ACCESS_LOG=true
